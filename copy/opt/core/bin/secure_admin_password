#!/opt/local/bin/ruby

pwd=%x[mdata-get kumquat_admin 2>/dev/null]

pwd=%x[mdata-get kumquat_admin_initial_pw 2>/dev/null] if pwd == ''


if pwd == ''
  puts "empty mdata password"
  exit
end

salt = rand(36 ** 8).to_s(36)

crypted_pwd = pwd.crypt("$5$#{salt}")

print crypted_pwd

# %x[cp /etc/shadow /etc/shadow.bak]
# %x[sed -i -e "s|www:NP:|www:#{crypted_pwd}:|" /etc/shadow]